NODE_ENV=development
APP_ENV=development

APP_URL=http://localhost:5173
API_URL=http://localhost:8080

SERVER_PORT=8080

# PostgreSQL Configuration
DATABASE_URL=postgres://mapaturbo:mapaturbo_password@localhost:5432/mapaturbo?sslmode=disable

# Redis Configuration (Used by Asynq)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
JWT_SECRET=change_me_to_a_secure_jwt_secret_key_32_bytes_or_more
JWT_EXPIRES_IN=168h
ENCRYPTION_KEY=change_me_to_exactly_32_bytes_key_

# Bootstrap/Seed Admin
BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
BOOTSTRAP_ADMIN_PASSWORD=@Admin2328

# MinIO Configuration (S3 Compatible Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mapaturbo
MINIO_SECRET_KEY=mapaturbo_password
MINIO_BUCKET=mapaturbo-files
MINIO_USE_SSL=false

DEFAULT_CURRENCY=BRL

# AI Providers API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Payment Gateways (Asaas Sandbox/Production)
ASAAS_ENV=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SUCCESS_URL=http://localhost:5173/app/billing/success
ASAAS_CANCEL_URL=http://localhost:5173/app/billing/cancel

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
